{
  "name": "coolify-ghcr-deploy",
  "version": "1.1.0",
  "description": "Deploy Docker images to Coolify via GitHub Container Registry",
  "keywords": [
    "container",
    "coolify",
    "deploy",
    "docker",
    "github",
    "registry"
  ],
  "license": "MIT",
  "author": "Assaf Arkin",
  "bin": {
    "coolify-ghcr-deploy": "./dist/cli.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && ncc build src/index.ts --source-map --license licenses.txt",
    "build:action": "ncc build src/index.ts --source-map --license licenses.txt",
    "prepack": "pnpm build && pnpm build:action",
    "prepublishOnly": "pnpm build && pnpm build:action",
    "test": "pnpm lint && fallow && knip && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "oxfmt --write",
    "lint": "oxlint --fix"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-v8": "^4.1.6",
    "fallow": "^2.71.1",
    "knip": "^6.13.1",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
