{
  "name": "coolify-ghcr-deploy",
  "version": "1.0.0",
  "description": "Deploy Docker images to Coolify via GitHub Container Registry",
  "keywords": [
    "container",
    "coolify",
    "deploy",
    "docker",
    "github",
    "registry"
  ],
  "license": "MIT",
  "author": "Assaf Arkin",
  "bin": {
    "coolify-ghcr-deploy": "./dist/cli.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:action": "ncc build src/index.ts --source-map --license licenses.txt",
    "prepack": "pnpm build && pnpm build:action",
    "prepublishOnly": "pnpm build && pnpm build:action",
    "test": "pnpm lint && knip && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "oxfmt --write",
    "lint": "oxlint --fix"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vercel/ncc": "^0.38.1",
    "@vitest/coverage-v8": "^4.1.5",
    "knip": "^6.12.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}